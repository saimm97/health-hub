# Copy to .env and fill in. Never commit your real .env.

# --- Core ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
# Leave unset to use local SQLite. For PostgreSQL (docker-compose):
# DATABASE_URL=postgres://healthhub:healthhub@localhost:5432/healthhub

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- CORS (Next.js dev server) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Payments (Stripe) — wired in the final phase ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (production SMTP) ---
DEFAULT_FROM_EMAIL=HealthHub <no-reply@healthhub.local>
